# ═══════════════════════════════════════════════════════════════
#  Eye of Horus — Environment Configuration
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ─────────────────────── Reddit API ───────────────────────
# Create an app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=eye-of-horus/1.0 by /u/your_username

# ─────────────────────── AlienVault OTX ───────────────────────
# Get FREE key at: https://otx.alienvault.com (register → API key tab)
OTX_API_KEY=your_otx_api_key_here

# ─────────────────────── Kafka ───────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=raw-osint
KAFKA_TOPIC_PROCESSED=processed-threats
KAFKA_TOPIC_ALERTS=threat-alerts
KAFKA_GROUP_ID=eye-of-horus-consumers

# ─────────────────────── MongoDB ───────────────────────
MONGO_URI=mongodb://eyeadmin:eyeofhorus2024@localhost:27017/
MONGO_DB_NAME=cyber_intel
MONGO_COLLECTION_RAW=raw_posts
MONGO_COLLECTION_THREATS=threat_scores
MONGO_COLLECTION_ALERTS=alerts

# ─────────────────────── ML / Threat Scoring ───────────────────────
# Weights for: Score = α·frequency + β·volume + γ·sentiment + δ·trend
THREAT_ALPHA=0.3
THREAT_BETA=0.2
THREAT_GAMMA=0.3
THREAT_DELTA=0.2
THREAT_SCORE_THRESHOLD=0.65

# ─────────────────────── Scraper Settings ───────────────────────
SCRAPE_INTERVAL_SECONDS=60
REDDIT_SUBREDDITS=cybersecurity,hacking,netsec,darknet,privacy,DataBreaches
REDDIT_POST_LIMIT=50
